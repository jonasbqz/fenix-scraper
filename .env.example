# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# General scraper behavior
# Modes:
# - m440_disabled: default. Runs Ikigai/Olympus/Nobledicion/Taurus; blocks M440.
# - m440_only: runs only M440/Peerless.
# - all: runs every scraper, including M440.
SCRAPER_MODE=m440_disabled
SCRAPER_RUN_ON_STARTUP=true
SCRAPER_STATUS_FILE=./scraper-status.json
SCRAPER_LOCK_FILE=./scraper-status.json.lock
SCRAPER_HEARTBEAT_SECONDS=30
SCRAPER_DELAY_MS=1000
# Delay between mango-image uploads (independent from HTML scrape delay). Default 0.
# MANGO_IMAGE_DELAY_MS=0
# Delay between chapters during backfill/upload. Default 0.
# MANGO_IMAGE_CHAPTER_DELAY_MS=0
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
LOG_LEVEL=

# Sources
SCRAPER_IKIGAI_URL=https://refered-worker.techcometserver.workers.dev
SCRAPER_NOBLEDICION_URL=https://nobledicion.net
# Madara site via mango-proxy (preferred). Origin: https://lectortaurus.com
SCRAPER_TAURUS_URL=https://fenix-proxy.knowledgeable-wishbone.workers.dev/taurus

# Worker schedule intervals for `bun run start`
SCRAPER_IKIGAI_INTERVAL_MIN=60
SCRAPER_OLYMPUS_INTERVAL_MIN=120
SCRAPER_NOBLEDICION_INTERVAL_MIN=120
SCRAPER_TAURUS_INTERVAL_MIN=120
SCRAPER_M440_INTERVAL_MIN=60

# Rule #3 backfill (mango-image).
# SCRAPER_BACKFILL_SCANS — comma-separated list of scans to backfill on a
#   schedule. Each scan's existing chapters in the DB are uploaded to
#   mango-image (idempotent — mango-image replaces by default). Empty =
#   backfill disabled. Only m440 and peerless are wired today; other
#   scans are ignored with a warning.
# SCRAPER_BACKFILL_INTERVAL_MIN — minutes between backfill runs per scan.
#   Default 30. Lock coordination with the scraper is out of scope for v1:
#   the backfill runs on its own schedule and may overlap with a scrape.
# SCRAPER_BACKFILL_SCANS=
# SCRAPER_BACKFILL_INTERVAL_MIN=30
# SCRAPER_SMART_BACKFILL=true   # default: catalog diff + Redis queue for m440/peerless
# REDIS_URL=redis://127.0.0.1:6379
# MANGO_UPLOAD_QUEUE_PREFIX=mango:upload
# MANGO_SMART_BACKFILL_MANGA_LIMIT=25   # top N mangas by views per run
# MANGO_SMART_BACKFILL_BATCH_SIZE=50    # images per Redis pop batch (grouped by chapter)

# M440 / Peerless
# Keep SCRAPER_MODE=m440_disabled by default, especially in production,
# because m440.in blocks IPs quickly.
SCRAPER_M440_URL=https://fenix-proxy.knowledgeable-wishbone.workers.dev/m440

# Scrapling / Cloudflare bypass for m440 (HTML scrape + image downloads).
# Runs scripts/m440-solve.py once (~30-60s), caches cookies ~20min, retries on 403.
# Debian/Ubuntu PEP 668: use venv — bash scripts/setup-scrapling-venv.sh (or bun run setup:scrapling)
# M440_SCRAPLING_COOKIES=true
# M440_PYTHON=python3
# M440_PYTHON=.venv-scrapling/bin/python3
# M440_SOLVE_SCRIPT=./scripts/m440-solve.py
# M440_COOKIE_TTL_MS=1200000
# Paste cookies from browser (overrides Scrapling when set):
# M440_COOKIE_HEADER=laravel_session=...; cf_clearance=...
# With cookies you MUST scrape direct origin — proxy ignores client cookies:
# SCRAPER_M440_URL=https://m440.in

# Local/proxy example:
# SCRAPER_MODE=m440_only
# SCRAPER_M440_URL=http://localhost:3228

# mango-image origin (for scraping → mango-image upload integration).
# MANGO_IMAGE_URL: base URL of the mango-image service (e.g. the
#   Dokploy/Traefik HTTPS URL). Required to call uploadImageToMangoImage.
# MANGO_IMAGE_API_KEY: shared secret — MUST match the value of
#   MANGO_IMAGE_API_KEY set on the mango-image service. The scraper
#   sends it as `Authorization: Bearer <key>` on POST /upload.
# Leave MANGO_IMAGE_URL unset to disable the upload integration
# (uploadImageToMangoImage will return ok=false with an error).
# MANGO_IMAGE_URL=https://cloud.otakux.wiki
# MANGO_IMAGE_API_KEY=
