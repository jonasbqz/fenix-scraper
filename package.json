{
  "name": "mango-scraper",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "bun run src/worker.ts",
    "status": "bun run src/status.ts",
    "scrape": "bun run src/main.ts",
    "scrape:all": "bun run src/main.ts all",
    "upload": "bun run src/commands/upload.ts",
    "upload:smart": "bun run src/commands/upload.ts peerless",
    "upload-proxy": "bun run src/commands/upload-proxy.ts",
    "fix-double-urls": "bun run src/fix-double-urls.ts",
    "fix-covers": "bun run src/fix-covers.ts",
    "image-test": "bun run src/m440-image-test.ts",
    "cookie-test": "bun run src/m440-cookie-test.ts",
    "setup:scrapling": "bash scripts/setup-scrapling-venv.sh",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build -d",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down",
    "docker:shell": "docker compose run --rm mango-scraper bash"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cheerio": "^1.0.0",
    "crypto-js": "^4.2.0",
    "drizzle-orm": "^0.33.0",
    "ioredis": "^5.4.2",
    "pg": "^8.12.0",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "bun-types": "^1.3.14",
    "typescript": "^7.0.0"
  }
}
