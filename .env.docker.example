# Copy to .env before: docker compose up --build -d
# cp .env.docker.example .env

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Scraper mode:
#   m440_disabled — ikigai/olympus/nobledicion (default for Gato / Ikigai)
#   m440_only     — only m440/peerless
#   all           — everything
SCRAPER_MODE=m440_disabled
SCRAPER_RUN_ON_STARTUP=true

# Ikigai (via referer worker)
SCRAPER_IKIGAI_URL=https://refered-worker.techcometserver.workers.dev
SCRAPER_IKIGAI_INTERVAL_MIN=60
SCRAPER_OLYMPUS_INTERVAL_MIN=120
SCRAPER_NOBLEDICION_INTERVAL_MIN=120
SCRAPER_NOBLEDICION_URL=https://nobledicion.net

# m440 / peerless (needs SCRAPER_MODE=m440_only or all + Scrapling)
# SCRAPER_M440_URL=https://mango-proxy.platformoctopus.workers.dev/m440
# SCRAPER_M440_INTERVAL_MIN=60
# M440_SCRAPLING_COOKIES=true
# MANGO_IMAGE_URL=https://cloud.otakux.wiki
# MANGO_IMAGE_API_KEY=
# SCRAPER_BACKFILL_SCANS=peerless
# SCRAPER_BACKFILL_INTERVAL_MIN=30
